# Copy this file to .dev.vars and fill in your values
# These are used by wrangler dev for local development

# OpenAI API key (for AI-generated trivia questions)
OPENAI_API_KEY=sk-...

# Anthropic API key (for scavenger hunt photo verification)
ANTHROPIC_API_KEY=sk-ant-...

# Resend API key (for magic code auth emails)
RESEND_API_KEY=re_...

# Stripe secret key (for credit purchases)
STRIPE_SECRET_KEY=sk_test_...

# Stripe webhook signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
